# ┌──────────────────────────────────────────────────────────────────────────────┐
# │  Pixxel GPT — Environment Variables Template                               │
# │  Copy this file to .env.local and fill in your values.                     │
# │  All values below are placeholders — DO NOT use them in production.        │
# └──────────────────────────────────────────────────────────────────────────────┘

# ─── Clerk Authentication (REQUIRED) ──────────────────────────────────────────
# Sign up at https://clerk.com → Create application → Copy keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE
CLERK_FRONTEND_API_URL=https://YOUR_INSTANCE.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://YOUR_INSTANCE.clerk.accounts.dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── ImageKit CDN & AI (REQUIRED) ────────────────────────────────────────────
# Sign up at https://imagekit.io → Dashboard → Developer options → API keys
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_YOUR_KEY_HERE
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/YOUR_ID
IMAGEKIT_PRIVATE_KEY=private_YOUR_KEY_HERE
# Enable signed AI URLs (background removal, upscale, etc.)
IMAGEKIT_SIGN_AI_URLS=true

# ─── Neon Database (REQUIRED) ────────────────────────────────────────────────
# Sign up at https://neon.tech → Create project → Connection string
# Use the pooled connection for DATABASE_URL and direct for DIRECT_URL
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── Upstash Redis (RECOMMENDED for production) ─────────────────────────────
# Sign up at https://upstash.com → Create database → REST API
# Without this, rate limiting and canvas snapshots use in-memory storage
# (works for single-instance but lost on restart).
# UPSTASH_REDIS_REST_URL=https://YOUR_INSTANCE.upstash.io
# UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN_HERE

# ─── Hugging Face (FREE — AI image generation & inpainting) ──────────────────
# Get a FREE token at https://huggingface.co/settings/tokens
# Used for: AI extend (outpaint), AI inpaint (object removal fill)
HUGGINGFACE_API_TOKEN=hf_YOUR_TOKEN_HERE

# ─── Google Gemini (FREE — AI edit planning) ─────────────────────────────────
# Get a FREE key at https://aistudio.google.com/apikey
# Used for: AI Agent edit planning, image analysis
GEMINI_API_KEY=YOUR_KEY_HERE

# ─── Unsplash (FREE — stock photos) ─────────────────────────────────────────
# Get a FREE key at https://unsplash.com/developers
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=YOUR_KEY_HERE

# ─── Mask Service (OPTIONAL — local Python AI service) ───────────────────────
# Only needed for: SAM2, Depth estimation, LaMa inpainting, CLIPSeg
# Deploy separately on Hugging Face Spaces or run locally
# MASK_SERVICE_URL=http://127.0.0.1:8001
