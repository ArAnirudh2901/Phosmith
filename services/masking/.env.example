# Phosmith Masking Service — copy to services/masking/.env and adjust.
# Endpoints: /segment, /segment/instances, /segment/box, /sam2/click, /depth,
# /ground/text. Proxied by the Next.js routes via MASKING_SERVICE_URL.

# The Next.js app reaches this service at (set in the phosmith .env.local):
#   MASKING_SERVICE_URL=http://127.0.0.1:8002

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8002
MAX_UPLOAD_MB=24
# Allow the Next.js dev origin (only relevant if the browser ever calls direct).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Subject saliency (rembg / BiRefNet) ──────────────────────────────────────
# birefnet-general (~973 MB) gives the most complete matte; -lite (~215 MB) is
# the low-RAM fallback. isnet-general-use (~168 MB) is the cross-platform default.
SEGMENT_MODEL=birefnet-general
SEGMENT_MAX_SIDE=2048

# ─── SAM 3.1 (concept / box / point / text grounding) ─────────────────────────
# Gated checkpoint — install facebookresearch/sam3 and `huggingface-cli login`
# (accept facebook/sam3.1 terms). Set SAM3_ENABLE=0 to force saliency-only.
SAM3_ENABLE=1
SAM3_MODEL_ID=facebook/sam3.1
# SAM3_CHECKPOINT_PATH=/data/models/sam3.1.pt   # local weights (skips HF download)
# 0.25 lets SAM 3 commit the full concept (e.g. whole sky); 0.5 only the core.
SAM3_CONFIDENCE=0.25
SAM3_SUBJECT_PROMPT=main subject
SAM3_INSTANCES_MAX=24
SAM2_MAX_CLICKS=50
# Preload SAM 3 at startup instead of first use (lowest first-request latency).
SAM3_EAGER=0

# ─── Depth Anything V2 (/depth) ───────────────────────────────────────────────
DEPTH_MODEL_ID=depth-anything/Depth-Anything-V2-Small-hf
DEPTH_CACHE_MAX=20
DEPTH_CACHE_MAX_PIXELS=4194304
DEPTH_MAX_SIDE=2048

# ─── Lazy loading ─────────────────────────────────────────────────────────────
# 0 (default) loads SAM 3 + Depth on first use (smaller resident footprint).
SEGMENT_EAGER_MODELS=0

# ─── Model cache (persist across restarts) ────────────────────────────────────
# HuggingFace Spaces with persistent storage: MODEL_CACHE_DIR=/data/models
# Docker volume:                              MODEL_CACHE_DIR=/models
# Leave unset locally (HF + rembg defaults already persist).
# MODEL_CACHE_DIR=/data/models
